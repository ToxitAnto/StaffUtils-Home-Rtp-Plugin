package it.staffplugin.commands;

import it.staffplugin.StaffPlugin;
import org.bukkit.Bukkit;
import org.bukkit.command.*;
import org.bukkit.entity.Player;

public class TptoCommand implements CommandExecutor {
    private final StaffPlugin plugin;
    public TptoCommand(StaffPlugin p) { this.plugin = p; }

    @Override
    public boolean onCommand(CommandSender sender, Command cmd, String label, String[] args) {
        if (!(sender instanceof Player player)) { sender.sendMessage(plugin.msg("player-only")); return true; }
        if (!player.hasPermission("staffplugin.staff.tpto")) { player.sendMessage(plugin.msg("no-permission")); return true; }
        if (args.length < 1) { player.sendMessage(StaffPlugin.colorize("&cUso: /tpto <player>")); return true; }

        Player target = Bukkit.getPlayer(args[0]);
        if (target == null) { player.sendMessage(plugin.msg("player-not-found").replace("{player}", args[0])); return true; }

        player.teleport(target.getLocation());
        player.sendMessage(StaffPlugin.colorize("&aTeleportato da &e" + target.getName() + "&a!"));
        return true;
    }
}
